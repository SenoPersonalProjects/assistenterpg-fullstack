import { AtributoBase, AtributoPassiva, Prisma } from '@prisma/client';

export type SeedHabilidade = {
  nome: string;
  tipo: string;

  // no seu projeto, você está usando origem como string ("GERAL")
  origem?: string | null;

  descricao?: string | null;
  hereditaria?: boolean;

  // Json (Prisma)
  requisitos?: Prisma.InputJsonValue | null;
  mecanicasEspeciais?: Prisma.InputJsonValue | null;
};

