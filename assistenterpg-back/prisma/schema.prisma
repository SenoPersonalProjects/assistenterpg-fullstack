// ========================================
// ✅ CATÁLOGO DE EQUIPAMENTOS
// ========================================

model EquipamentoCatalogo {
  id        Int                  @id @default(autoincrement())
  codigo    String               @unique
  nome      String
  descricao String?              @db.Text
  tipo      TipoEquipamento
  categoria CategoriaEquipamento @default(CATEGORIA_0)
  espacos   Int                  @default(1)

  // ✅ NOVO: Fonte e suplemento
  fonte        TipoFonte   @default(SISTEMA_BASE)
  suplementoId Int?
  suplemento   Suplemento? @relation(fields: [suplementoId], references: [id], onDelete: SetNull)

  proficienciaArma ProficienciaArma?
  empunhaduras     Json?
  tipoArma         TipoArma?
  subtipoDistancia SubtipoArmaDistancia?
  agil             Boolean               @default(false)

  criticoValor         Int?
  criticoMultiplicador Int?
  alcance              AlcanceArma?
  tipoMunicaoCodigo    String?
  habilidadeEspecial   String?      @db.Text

  duracaoCenas Int?
  recuperavel  Boolean @default(false)

  proficienciaProtecao ProficienciaProtecao?
  tipoProtecao         TipoProtecao?
  bonusDefesa          Int                   @default(0)
  penalidadeCarga      Int                   @default(0)

  tipoAcessorio     TipoAcessorio?
  periciaBonificada String?
  bonusPericia      Int            @default(0)
  requereEmpunhar   Boolean        @default(false)
  maxVestimentas    Int            @default(0)

  tipoExplosivo TipoExplosivo?

  // ✅ CORRIGIDO: Mudou de tipoAmaldicoado (antigo) para tipoUso
  tipoUso         TipoUsoEquipamento?
  // ✅ NOVO: Tipo do amaldiçoado (ARMA, PROTECAO, ITEM, ARTEFATO)
  tipoAmaldicoado TipoAmaldicoado?

  efeito String? @db.Text

  complexidadeMaldicao          ComplexidadeMaldicao @default(NENHUMA)
  efeitoMaldicao                String?              @db.Text
  requerFerramentasAmaldicoadas Boolean              @default(false)

  modificacoesAplicaveis EquipamentoModificacaoAplicavel[]

  danos       EquipamentoDano[]        @relation("EquipamentoDano")
  reducesDano EquipamentoReducaoDano[] @relation("EquipamentoReducaoDano")

  armaAmaldicoada     ArmaAmaldicoada?
  protecaoAmaldicoada ProtecaoAmaldicoada?
  artefatoAmaldicoado ArtefatoAmaldicoado?

  itensBase     InventarioItemBase[]
  itensCampanha InventarioItemCampanha[]

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([tipo])
  @@index([categoria])
  @@index([tipoAmaldicoado])
  @@index([fonte])
  @@index([suplementoId])
  @@map("equipamento_catalogo")
}

