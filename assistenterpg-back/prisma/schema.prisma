  equipamentoId Int
  equipamento   EquipamentoCatalogo @relation("EquipamentoReducaoDano", fields: [equipamentoId], references: [id], onDelete: Cascade)

  tipoReducao TipoReducaoDano
  valor       Int             @default(0)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@unique([equipamentoId, tipoReducao])
  @@index([equipamentoId])
  @@index([tipoReducao])
  @@map("equipamento_reducao_dano")
}

