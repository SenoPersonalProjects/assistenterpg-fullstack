  VERIFICACAO_EMAIL
}

enum CampoModificadorPersonagemCampanha {
  PV_MAX
  PE_MAX
  EA_MAX
  SAN_MAX
  DEFESA_BASE
  DEFESA_EQUIPAMENTO
  DEFESA_OUTROS
  ESQUIVA
