// ========================================
// ✅ MODIFICAÇÕES DE EQUIPAMENTOS
// ========================================

model ModificacaoEquipamento {
  id                Int             @id @default(autoincrement())
  codigo            String          @unique
  nome              String
  descricao         String?         @db.Text
  tipo              TipoModificacao
  incrementoEspacos Int             @default(1)

  // ✅ NOVO: Sistema de restrições flexível
  restricoes Json?

  // ✅ Efeitos mecânicos (bonus, penalidades, etc)
  efeitosMecanicos Json?

  // ✅ Fonte e suplemento
  fonte        TipoFonte   @default(SISTEMA_BASE)
  suplementoId Int?
  suplemento   Suplemento? @relation(fields: [suplementoId], references: [id], onDelete: SetNull)

  equipamentosApplicaveis EquipamentoModificacaoAplicavel[]
  itensBase               InventarioItemBaseModificacao[]
  itensCampanha           InventarioItemCampanhaModificacao[]

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([tipo])
  @@index([fonte])
  @@index([suplementoId])
  @@map("modificacao_equipamento")
}

model EquipamentoModificacaoAplicavel {
  id            Int @id @default(autoincrement())
  equipamentoId Int
  modificacaoId Int

  equipamento EquipamentoCatalogo    @relation(fields: [equipamentoId], references: [id], onDelete: Cascade)
  modificacao ModificacaoEquipamento @relation(fields: [modificacaoId], references: [id], onDelete: Cascade)

  @@unique([equipamentoId, modificacaoId])
  @@map("equipamento_modificacao_aplicavel")
