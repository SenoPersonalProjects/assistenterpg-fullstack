// ========================================
// ✅ INVENTÁRIO - PERSONAGEM CAMPANHA
// ========================================

model InventarioItemCampanha {
  id                   Int                @id @default(autoincrement())
  personagemCampanhaId Int
  personagemCampanha   PersonagemCampanha @relation("InventarioCampanha", fields: [personagemCampanhaId], references: [id], onDelete: Cascade)

  equipamentoId Int
  equipamento   EquipamentoCatalogo @relation(fields: [equipamentoId], references: [id])

  quantidade Int     @default(1)
  equipado   Boolean @default(false)

  categoriaCalculada CategoriaEquipamento @default(CATEGORIA_0)

  modificacoes InventarioItemCampanhaModificacao[]

  nomeCustomizado String?
  notas           String? @db.Text

  estado Json?

  criadoEm     DateTime @default(now())
