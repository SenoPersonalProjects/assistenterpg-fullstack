  FOGO
  ELETRICIDADE
  FRIO
  ENERGIA_AMALDICOADA
  ENERGIA_POSITIVA
  MENTAL
  FISICO // ✅ NOVO: Guarda-chuva
  SOBRENATURAL // ✅ NOVO: Guarda-chuva
  MUNDANO // ✅ NOVO: Guarda-chuva
}

