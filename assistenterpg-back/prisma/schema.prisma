  PEQUENO
  MEDIO
  GRANDE
  ENORME
  COLOSSAL
}

// ========================================
// ✅ USUÁRIOS E CAMPANHAS
// ========================================

model Usuario {
  id                Int       @id @default(autoincrement())
  apelido           String
  email             String    @unique
  senhaHash         String
  emailVerificadoEm DateTime?

  // ✅ NOVO: Role do usuário
  role RoleUsuario @default(USUARIO)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  campanhasQuePossui                       Campanha[]                             @relation("CampanhasDoDono")
  personagensBase                          PersonagemBase[]
  personagensCampanha                      PersonagemCampanha[]                   @relation("PersonagensCampanhaDoDono")
  membrosCampanha                          MembroCampanha[]
  historicosPersonagemCampanha             PersonagemCampanhaHistorico[]
  modificadoresPersonagemCampanhaCriados   PersonagemCampanhaModificador[]        @relation("ModificadorPersonagemCampanhaCriadoPor")
  modificadoresPersonagemCampanhaDesfeitos PersonagemCampanhaModificador[]        @relation("ModificadorPersonagemCampanhaDesfeitoPor")
  sustentacoesSessaoCriadas                PersonagemSessaoHabilidadeSustentada[] @relation("SustentacaoSessaoCriadaPor")
  sustentacoesSessaoDesativadas            PersonagemSessaoHabilidadeSustentada[] @relation("SustentacaoSessaoDesativadaPor")
  npcsAmeacas                              NpcAmeaca[]
  preferencias                             PreferenciaUsuario?
  tokensAuth                               AuthToken[]

  // ✅ NOVO: Relações com suplementos e homebrews
  suplementosAtivos UsuarioSuplemento[]
  homebrews         Homebrew[]
}

model AuthToken {
  id        Int           @id @default(autoincrement())
  usuarioId Int
  tipo      TipoTokenAuth
  tokenHash String        @unique
  expiraEm  DateTime
  usadoEm   DateTime?
  criadoEm  DateTime      @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, tipo, usadoEm], map: "AuthToken_usuario_tipo_usado_idx")
  @@index([tipo, expiraEm], map: "AuthToken_tipo_expira_idx")
  @@map("auth_tokens")
}

model Campanha {
  id           Int      @id @default(autoincrement())
  donoId       Int
  nome         String
  descricao    String?  @db.Text
  status       String
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  dono                     Usuario                         @relation("CampanhasDoDono", fields: [donoId], references: [id], onDelete: Cascade)
  membros                  MembroCampanha[]
  personagens              PersonagemCampanha[]
  historicoPersonagens     PersonagemCampanhaHistorico[]
  modificadoresPersonagens PersonagemCampanhaModificador[]
  sessoes                  Sessao[]
  convites                 ConviteCampanha[]

  @@index([donoId])
  @@index([donoId, criadoEm])
}

model MembroCampanha {
  id         Int      @id @default(autoincrement())
  campanhaId Int
  usuarioId  Int
  papel      String
  entrouEm   DateTime @default(now())

  campanha Campanha @relation(fields: [campanhaId], references: [id], onDelete: Cascade)
  usuario  Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([campanhaId, usuarioId])
  @@index([usuarioId])
  @@index([usuarioId, campanhaId])
}

// ========================================
// ✅ PERSONAGENS
// ========================================

model PersonagemBase {
  id     Int    @id @default(autoincrement())
  donoId Int
  nome   String
  nivel  Int

  claId     Int
  origemId  Int
  classeId  Int
  trilhaId  Int?
  caminhoId Int?

  agilidade Int
  forca     Int
  intelecto Int
  presenca  Int
  vigor     Int

  estudouEscolaTecnica Boolean @default(false)

  tecnicaInataId Int?
  tecnicaInata   TecnicaAmaldicoada? @relation("TecnicaInataPersonagemBase", fields: [tecnicaInataId], references: [id])

  passivas                PersonagemBasePassiva[]
  passivasAtributosAtivos Json?
  passivasAtributosConfig Json?

  proficiencias              PersonagemBaseProficiencia[]
  proficienciasExtrasCodigos Json?

  pericias PersonagemBasePericia[]

  grausTreinamento   GrauTreinamentoPersonagemBase[]
  grausAprimoramento GrauPersonagemBase[]

  idade            Int?
  prestigioBase    Int     @default(0)
  prestigioClaBase Int?
  alinhamentoId    Int?
  background       String? @db.Text

  atributoChaveEa AtributoBaseEA @default(INT)

  espacosInventarioBase  Int     @default(0)
  espacosInventarioExtra Int     @default(0)
  espacosOcupados        Int     @default(0)
  sobrecarregado         Boolean @default(false)

  periciasClasseEscolhidasCodigos Json?
  periciasOrigemEscolhidasCodigos Json?
  periciasLivresCodigos           Json?

  pvMaximo  Int @default(0)
  peMaximo  Int @default(0)
  eaMaximo  Int @default(0)
  sanMaximo Int @default(0)

  // ✅ NOVO: Separar defesa base e bônus de equipamento
  defesaBase        Int @default(10)
  defesaEquipamento Int @default(0)
  defesaOutros      Int @default(0)

  deslocamento        Int @default(9)
  limitePeEaPorTurno  Int @default(1)
  reacoesBasePorTurno Int @default(2)
  turnosMorrendo      Int @default(3)
  turnosEnlouquecendo Int @default(3)
  bloqueio            Int @default(0)
  esquiva             Int @default(0)

  // ✅ NOVO: Resistências (igual PersonagemCampanha)
  resistencias PersonagemBaseResistencia[]

  dono        Usuario      @relation(fields: [donoId], references: [id])
  cla         Cla          @relation(fields: [claId], references: [id])
  origem      Origem       @relation(fields: [origemId], references: [id])
  classe      Classe       @relation(fields: [classeId], references: [id])
  trilha      Trilha?      @relation(fields: [trilhaId], references: [id])
  caminho     Caminho?     @relation(fields: [caminhoId], references: [id])
  alinhamento Alinhamento? @relation(fields: [alinhamentoId], references: [id])

  inventarioItens     InventarioItemBase[]
  personagensCampanha PersonagemCampanha[]
  habilidadesBase     HabilidadePersonagemBase[]
  poderesGenericos    PoderGenericoPersonagemBase[]
  tecnicasAprendidas  PersonagemBaseTecnica[]

  @@index([donoId])
  @@index([donoId, nome])
}

model NpcAmeaca {
  id        Int                @id @default(autoincrement())
  donoId    Int
  nome      String
  descricao String?            @db.Text
  fichaTipo TipoFichaNpcAmeaca @default(AMEACA)
  tipo      TipoNpcAmeaca
  tamanho   TamanhoNpcAmeaca   @default(MEDIO)
  vd        Int                @default(0)

  agilidade Int @default(0)
  forca     Int @default(0)
  intelecto Int @default(0)
  presenca  Int @default(0)
  vigor     Int @default(0)

  percepcao  Int @default(0)
  iniciativa Int @default(0)
  fortitude  Int @default(0)
  reflexos   Int @default(0)
  vontade    Int @default(0)
  luta       Int @default(0)
  jujutsu    Int @default(0)

  percepcaoDados  Int?
  iniciativaDados Int?
  fortitudeDados  Int?
  reflexosDados   Int?
  vontadeDados    Int?
  lutaDados       Int?
  jujutsuDados    Int?

  defesa     Int  @default(10)
  pontosVida Int  @default(1)
  machucado  Int?

  deslocamentoMetros Int @default(6)

  periciasEspeciais Json?
  resistencias      Json?
  vulnerabilidades  Json?
  passivas          Json?
  acoes             Json?
  usoTatico         String? @db.Text

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  dono             Usuario           @relation(fields: [donoId], references: [id], onDelete: Cascade)
  instanciasSessao NpcAmeacaSessao[]

  @@index([donoId])
  @@index([donoId, nome])
}

model PersonagemCampanha {
  id               Int @id @default(autoincrement())
  campanhaId       Int
  personagemBaseId Int
  donoId           Int

  nome      String
  nivel     Int
  claId     Int
  origemId  Int
  classeId  Int
  trilhaId  Int?
  caminhoId Int?

  pvMax    Int
  pvAtual  Int
  peMax    Int
  peAtual  Int
  eaMax    Int
  eaAtual  Int
  sanMax   Int
  sanAtual Int

  limitePeEaPorTurno Int

  prestigioGeral Int  @default(0)
  prestigioCla   Int?

  // ✅ JÁ EXISTE: Campos de defesa separados (correto!)
  defesaBase        Int @default(10)
  defesaEquipamento Int @default(0)
  defesaOutros      Int @default(0)

  esquiva  Int @default(0)
  bloqueio Int @default(0)

  // ✅ JÁ EXISTE: Resistências
  resistencias PersonagemCampanhaResistencia[]

  deslocamento Int @default(9)

  turnosMorrendo      Int @default(3)
  turnosEnlouquecendo Int @default(3)

  espacosInventarioBase  Int     @default(0)
  espacosInventarioExtra Int     @default(0)
  espacosOcupados        Int     @default(0)
  sobrecarregado         Boolean @default(false)

  tecnicaInataId Int?
  tecnicaInata   TecnicaAmaldicoada? @relation("TecnicaInataPersonagemCampanha", fields: [tecnicaInataId], references: [id])

  campanha       Campanha       @relation(fields: [campanhaId], references: [id], onDelete: Cascade)
  personagemBase PersonagemBase @relation(fields: [personagemBaseId], references: [id], onDelete: Cascade)
  dono           Usuario        @relation("PersonagensCampanhaDoDono", fields: [donoId], references: [id], onDelete: Cascade)
  cla            Cla            @relation(fields: [claId], references: [id])
  origem         Origem         @relation(fields: [origemId], references: [id])
  classe         Classe         @relation(fields: [classeId], references: [id])
  trilha         Trilha?        @relation(fields: [trilhaId], references: [id])
  caminho        Caminho?       @relation(fields: [caminhoId], references: [id])

  personagensSessao   PersonagemSessao[]
  habilidadesCampanha HabilidadePersonagemCampanha[]
  inventarioItens     InventarioItemCampanha[]          @relation("InventarioCampanha")
  grausAprimoramento  GrauPersonagemCampanha[]
  poderesGenericos    PoderGenericoPersonagemCampanha[]
  tecnicasAprendidas  PersonagemCampanhaTecnica[]
  historico           PersonagemCampanhaHistorico[]
  modificadores       PersonagemCampanhaModificador[]

  @@unique([campanhaId, personagemBaseId])
  @@index([campanhaId])
  @@index([campanhaId, donoId])
  @@index([personagemBaseId])
  @@index([donoId])
}

model PersonagemCampanhaHistorico {
  id                   Int      @id @default(autoincrement())
  personagemCampanhaId Int
  campanhaId           Int
  criadoPorId          Int?
  tipo                 String
  descricao            String?  @db.Text
  dados                Json?
  criadoEm             DateTime @default(now())

  personagemCampanha PersonagemCampanha @relation(fields: [personagemCampanhaId], references: [id], onDelete: Cascade)
  campanha           Campanha           @relation(fields: [campanhaId], references: [id], onDelete: Cascade)
  criadoPor          Usuario?           @relation(fields: [criadoPorId], references: [id], onDelete: SetNull)

  @@index([personagemCampanhaId, criadoEm])
  @@index([campanhaId, criadoEm])
}

model PersonagemCampanhaModificador {
  id                   Int                                @id @default(autoincrement())
  personagemCampanhaId Int
  campanhaId           Int
  sessaoId             Int?
  cenaId               Int?
  campo                CampoModificadorPersonagemCampanha
  valor                Int
  nome                 String
  descricao            String?                            @db.Text
  ativo                Boolean                            @default(true)
  criadoPorId          Int
  criadoEm             DateTime                           @default(now())
  desfeitoPorId        Int?
  desfeitoEm           DateTime?
  motivoDesfazer       String?                            @db.Text

  personagemCampanha PersonagemCampanha @relation(fields: [personagemCampanhaId], references: [id], onDelete: Cascade)
  campanha           Campanha           @relation(fields: [campanhaId], references: [id], onDelete: Cascade)
  criadoPor          Usuario            @relation("ModificadorPersonagemCampanhaCriadoPor", fields: [criadoPorId], references: [id], onDelete: Cascade)
  desfeitoPor        Usuario?           @relation("ModificadorPersonagemCampanhaDesfeitoPor", fields: [desfeitoPorId], references: [id], onDelete: SetNull)

  @@index([personagemCampanhaId, ativo])
  @@index([campanhaId, criadoEm])
  @@index([sessaoId])
  @@index([cenaId])
  @@index([campanhaId, personagemCampanhaId, sessaoId, ativo], map: "PCM_camp_pers_sess_ativo_idx")
  @@index([campanhaId, personagemCampanhaId, cenaId, ativo], map: "PCM_camp_pers_cena_ativo_idx")
}

model Sessao {
  id               Int       @id @default(autoincrement())
  campanhaId       Int
  titulo           String
  status           String    @default("LOBBY")
  rodadaAtual      Int       @default(1)
  indiceTurnoAtual Int       @default(0)
  cenaAtualTipo    String    @default("LIVRE")
  cenaAtualNome    String?
  iniciadoEm       DateTime  @default(now())
  encerradoEm      DateTime?

  campanha               Campanha                               @relation(fields: [campanhaId], references: [id], onDelete: Cascade)
  cenas                  Cena[]
  personagens            PersonagemSessao[]                     @relation("PersonagensDaSessao")
  npcs                   NpcAmeacaSessao[]
  habilidadesSustentadas PersonagemSessaoHabilidadeSustentada[]
  condicoes              CondicaoPersonagemSessao[]
  eventos                EventoSessao[]

  @@index([campanhaId, iniciadoEm])
}

model Cena {
  id       Int @id @default(autoincrement())
  sessaoId Int

  sessao      Sessao                     @relation(fields: [sessaoId], references: [id])
  personagens PersonagemSessao[]         @relation("PersonagensDaCena")
  npcs        NpcAmeacaSessao[]
  condicoes   CondicaoPersonagemSessao[]
  eventos     EventoSessao[]
}

model NpcAmeacaSessao {
  id                 Int                @id @default(autoincrement())
  sessaoId           Int
  cenaId             Int?
  npcAmeacaId        Int?
  nomeExibicao       String
  fichaTipo          TipoFichaNpcAmeaca @default(AMEACA)
  tipo               TipoNpcAmeaca
  vd                 Int                @default(0)
  iniciativaValor    Int?
  defesa             Int                @default(10)
  pontosVidaAtual    Int                @default(1)
  pontosVidaMax      Int                @default(1)
  sanAtual           Int?
  sanMax             Int?
  eaAtual            Int?
  eaMax              Int?
  machucado          Int?
  deslocamentoMetros Int                @default(6)
  passivasGuia       Json?
  acoesGuia          Json?
  notasCena          String?            @db.Text
  criadoEm           DateTime           @default(now())
  atualizadoEm       DateTime           @updatedAt

  sessao    Sessao                     @relation(fields: [sessaoId], references: [id], onDelete: Cascade)
  cena      Cena?                      @relation(fields: [cenaId], references: [id], onDelete: SetNull)
  npcAmeaca NpcAmeaca?                 @relation(fields: [npcAmeacaId], references: [id], onDelete: SetNull)
  condicoes CondicaoPersonagemSessao[]

  @@index([sessaoId])
  @@index([cenaId])
  @@index([npcAmeacaId])
  @@index([sessaoId, cenaId])
}

model PersonagemSessao {
  id                   Int  @id @default(autoincrement())
  sessaoId             Int
  cenaId               Int?
  personagemCampanhaId Int
  iniciativaValor      Int?

  sessao             Sessao             @relation("PersonagensDaSessao", fields: [sessaoId], references: [id])
  cena               Cena?              @relation("PersonagensDaCena", fields: [cenaId], references: [id])
  personagemCampanha PersonagemCampanha @relation(fields: [personagemCampanhaId], references: [id])

  condicoes              CondicaoPersonagemSessao[]
  habilidadesSustentadas PersonagemSessaoHabilidadeSustentada[]
  eventosComoAtor        EventoSessao[]                         @relation("EventosComoAtor")
  eventosComoAlvo        EventoSessao[]                         @relation("EventosComoAlvo")
}

model PersonagemSessaoHabilidadeSustentada {
  id                   Int  @id @default(autoincrement())
  sessaoId             Int
  personagemSessaoId   Int
  habilidadeTecnicaId  Int
  variacaoHabilidadeId Int?

  nomeHabilidade         String
  nomeVariacao           String?
  custoSustentacaoEA     Int       @default(1)
  custoSustentacaoPE     Int       @default(0)
  ativadaNaRodada        Int       @default(1)
  ultimaCobrancaRodada   Int       @default(1)
  ativa                  Boolean   @default(true)
  criadaPorUsuarioId     Int
  criadoEm               DateTime  @default(now())
  desativadaEm           DateTime?
  desativadaPorUsuarioId Int?
  motivoDesativacao      String?   @db.Text

  sessao             Sessao              @relation(fields: [sessaoId], references: [id], onDelete: Cascade)
  personagemSessao   PersonagemSessao    @relation(fields: [personagemSessaoId], references: [id], onDelete: Cascade)
  habilidadeTecnica  HabilidadeTecnica   @relation(fields: [habilidadeTecnicaId], references: [id], onDelete: Cascade)
  variacaoHabilidade VariacaoHabilidade? @relation(fields: [variacaoHabilidadeId], references: [id], onDelete: SetNull)
  criadaPor          Usuario             @relation("SustentacaoSessaoCriadaPor", fields: [criadaPorUsuarioId], references: [id], onDelete: Cascade)
  desativadaPor      Usuario?            @relation("SustentacaoSessaoDesativadaPor", fields: [desativadaPorUsuarioId], references: [id], onDelete: SetNull)

  @@index([sessaoId, ativa])
  @@index([personagemSessaoId, ativa])
