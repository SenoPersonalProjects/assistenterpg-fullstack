// ========================================
// ✅ SCHEMA PRISMA COMPLETO
// ========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ========================================
// ✅ ENUMS - TIPOS
// ========================================

