  @@index([personagemBaseId])
  @@index([equipamentoId])
  @@map("inventario_item_base")
}

model InventarioItemBaseModificacao {
  id            Int @id @default(autoincrement())
  itemId        Int
  modificacaoId Int

  item        InventarioItemBase     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  modificacao ModificacaoEquipamento @relation(fields: [modificacaoId], references: [id])

  @@unique([itemId, modificacaoId])
  @@map("inventario_item_base_modificacao")
