// ========================================
// ✅ TÉCNICA AMALDIÇOADA (CONTAINER)
// ========================================

model TecnicaAmaldicoada {
  id        Int    @id @default(autoincrement())
  codigo    String @unique
  nome      String @unique
  descricao String @db.Text

  tipo TipoTecnicaAmaldicoada

  // ✅ Para técnicas inatas hereditárias (ex: Técnicas de Clã)
  hereditaria Boolean      @default(false)
  clas        TecnicaCla[] // Múltiplos clãs podem ter a mesma técnica

  // ✅ Link externo (documentação, wiki, etc)
  linkExterno String? @db.Text

  // ✅ Requisitos gerais da técnica (JSON livre)
  requisitos Json? // Ex: { "nivel": 5, "atributo": "INT >= 3" }

  // ✅ NOVO: Fonte e suplemento
  fonte        TipoFonte   @default(SISTEMA_BASE)
  suplementoId Int?
  suplemento   Suplemento? @relation(fields: [suplementoId], references: [id], onDelete: SetNull)

  // ✅ Habilidades da técnica
  habilidades HabilidadeTecnica[]

  // ✅ Personagens que possuem essa técnica inata
  personagensBaseComInata     PersonagemBase[]     @relation("TecnicaInataPersonagemBase")
  personagensCampanhaComInata PersonagemCampanha[] @relation("TecnicaInataPersonagemCampanha")

  // ✅ Personagens que aprenderam técnicas não-inatas
  personagensBaseAprendeu     PersonagemBaseTecnica[]
  personagensCampanhaAprendeu PersonagemCampanhaTecnica[]

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([tipo])
  @@index([hereditaria])
  @@index([fonte])
  @@index([suplementoId])
  @@map("tecnica_amaldicoada")
}

// ========================================
// ✅ RELAÇÃO CLÃ <-> TÉCNICA (N:N)
// ========================================

model TecnicaCla {
  id        Int @id @default(autoincrement())
  tecnicaId Int
  claId     Int

  tecnica TecnicaAmaldicoada @relation(fields: [tecnicaId], references: [id], onDelete: Cascade)
  cla     Cla                @relation(fields: [claId], references: [id], onDelete: Cascade)

  @@unique([tecnicaId, claId])
  @@map("tecnica_cla")
}

// ========================================
// ✅ HABILIDADE DE TÉCNICA
// ========================================

model HabilidadeTecnica {
  id        Int                @id @default(autoincrement())
  tecnicaId Int
  tecnica   TecnicaAmaldicoada @relation(fields: [tecnicaId], references: [id], onDelete: Cascade)

  codigo    String @unique
  nome      String
  descricao String @db.Text

  // ✅ Requisitos estruturados (JSON)
  // Formato: { "Nível": 5, "Grau de Aprimoramento em Técnica Amaldiçoada": 2 }
  requisitos Json?

  // ✅ Execução
  execucao TipoExecucao
  area     AreaEfeito?

  alcance String?

  alvo    String? // Ex: "Você", "1 criatura", "Todos em alcance curto"
  duracao String? // Ex: "Instantâneo", "Sustentado", "3 turnos", "1 cena"

  // ✅ Resistência
  resistencia   String? @db.Text // Ex: "Fortitude", "Reflexos", "Vontade"
  dtResistencia String? @db.Text // Ex: "10 + Limite PE/EA + INT", "CD 15 fixa"

  // ✅ Custos base
  custoPE            Int  @default(0)
  custoEA            Int  @default(0)
  custoSustentacaoEA Int?
  custoSustentacaoPE Int?

  // ✅ Teste exigido (perícias necessárias)
  testesExigidos Json? // Ex: ["Atletismo", "Acrobacia"]

  // ✅ Dano base
  criticoValor         Int? // Ex: 19 (crítico em 19-20)
  criticoMultiplicador Int? // Ex: 2 (x2), 3 (x3)

  // ✅ ATUALIZADO: Dano flat com tipo (SOBRESCREVE se definido)
  danoFlat     Int?      @default(0)
  danoFlatTipo TipoDano?

  // ✅ Dados de dano (array JSON)
  dadosDano Json? // Ex: [{ "quantidade": 1, "dado": "d4", "tipo": "CORTANTE" }, { "quantidade": 2, "dado": "d6", "tipo": "IMPACTO" }]

  // ✅ Escalonamento por grau de aprimoramento
  escalonaPorGrau      Boolean                     @default(false)
  grauTipoGrauCodigo   String? // Qual grau usar (ex: "TECNICA_AMALDICOADA")
  escalonamentoCustoEA Int                         @default(0) // Custo adicional por grau investido
  escalonamentoCustoPE Int                         @default(0) // Custo adicional de PE por acumulo
  escalonamentoTipo    TipoEscalonamentoHabilidade @default(OUTRO)
  escalonamentoEfeito  Json? // Estrutura tipada por tipo de escalonamento
  escalonamentoDano    Json? // Ex: { "quantidade": 1, "dado": "d4", "tipo": "CORTANTE" } (adiciona por grau)

  // ✅ Efeito (texto livre)
  efeito String @db.Text

  // ✅ Variações (Liberação Superior/Máxima)
  variacoes          VariacaoHabilidade[]
  sustentacoesSessao PersonagemSessaoHabilidadeSustentada[]

  // ✅ Ordem de exibição
  ordem Int @default(0)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([tecnicaId])
  @@index([ordem])
  @@index([grauTipoGrauCodigo])
  @@map("habilidade_tecnica")
}

// ========================================
// ✅ VARIAÇÃO DE HABILIDADE
// ========================================

model VariacaoHabilidade {
  id                  Int               @id @default(autoincrement())
  habilidadeTecnicaId Int
  habilidadeTecnica   HabilidadeTecnica @relation(fields: [habilidadeTecnicaId], references: [id], onDelete: Cascade)

  nome      String // Ex: "Liberação Superior", "Liberação Máxima"
  descricao String @db.Text

  // ✅ Custos (SOBRESCREVE custos base se definido, senão ADICIONA)
  substituiCustos    Boolean @default(false) // true = substitui, false = adiciona
  custoPE            Int?
  custoEA            Int?
  custoSustentacaoEA Int?
  custoSustentacaoPE Int?

  // ✅ Execução (opcional - sobrescreve se definido)
  execucao TipoExecucao?
  area     AreaEfeito?
  alcance  String? // Ex: "12 m", "MEDIO"
  alvo     String?       @db.Text
  duracao  String?       @db.Text

  // ✅ Resistência (opcional - sobrescreve se definido)
  resistencia   String? @db.Text
  dtResistencia String? @db.Text

  // ✅ Dano (SOBRESCREVE se definido)
  criticoValor         Int?
  criticoMultiplicador Int?

  // ✅ ATUALIZADO: Dano flat com tipo (SOBRESCREVE se definido)
  danoFlat     Int?
  danoFlatTipo TipoDano?

  dadosDano Json? // Mesmo formato da habilidade base

  // ✅ Escalonamento (opcional - sobrescreve se definido)
  escalonaPorGrau      Boolean?
  escalonamentoCustoEA Int?
  escalonamentoCustoPE Int?
  escalonamentoTipo    TipoEscalonamentoHabilidade?
  escalonamentoEfeito  Json?
  escalonamentoDano    Json?

  // ✅ Efeito (ADICIONA ao efeito base)
  efeitoAdicional String? @db.Text

  // ✅ Requisitos específicos da variação
  requisitos Json? // Era: requisitos String? @db.Text

  // ✅ Ordem de exibição
  ordem Int @default(0)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  sustentacoesSessao PersonagemSessaoHabilidadeSustentada[]

  @@index([habilidadeTecnicaId])
  @@index([ordem])
  @@map("variacao_habilidade")
}

// ========================================
// ✅ PERSONAGEM BASE - TÉCNICAS
// ========================================

model PersonagemBaseTecnica {
  id               Int @id @default(autoincrement())
  personagemBaseId Int
  tecnicaId        Int

  personagemBase PersonagemBase     @relation(fields: [personagemBaseId], references: [id], onDelete: Cascade)
  tecnica        TecnicaAmaldicoada @relation(fields: [tecnicaId], references: [id])

  @@unique([personagemBaseId, tecnicaId])
  @@index([personagemBaseId])
  @@index([tecnicaId])
  @@map("personagem_base_tecnica")
}

model PersonagemCampanhaTecnica {
  id                   Int @id @default(autoincrement())
  personagemCampanhaId Int
  tecnicaId            Int

  personagemCampanha PersonagemCampanha @relation(fields: [personagemCampanhaId], references: [id], onDelete: Cascade)
  tecnica            TecnicaAmaldicoada @relation(fields: [tecnicaId], references: [id])

  @@unique([personagemCampanhaId, tecnicaId])
  @@index([personagemCampanhaId])
  @@index([tecnicaId])
  @@map("personagem_campanha_tecnica")
}

// ========================================
// ✅ SUPLEMENTOS
// ========================================

model Suplemento {
  id        Int              @id @default(autoincrement())
  codigo    String           @unique // Ex: "KAKYN", "HIDDEN_INVENTORY"
  nome      String
  descricao String?          @db.Text
  versao    String           @default("1.0.0")
  status    StatusPublicacao @default(RASCUNHO)

  // ✅ Visual
  icone  String? @db.Text // URL da imagem de ícone
  banner String? @db.Text // URL do banner

  // ✅ Metadados
  tags  Json? // ["Kakyn", "Geografia", "Clãs"]
  autor String? // Nome do criador (se aplicável)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  // ✅ Relações: Conteúdo do suplemento
  cla          Cla[]
  classes      Classe[]
  trilhas      Trilha[]
  caminhos     Caminho[]
  origens      Origem[]
  equipamentos EquipamentoCatalogo[]
  habilidades  Habilidade[]
  tecnicas     TecnicaAmaldicoada[]
  modificacoes ModificacaoEquipamento[]

  // ✅ Usuários que ativaram este suplemento
  usuariosAtivos UsuarioSuplemento[]

  @@index([status])
  @@index([codigo])
  @@map("suplementos")
}

// ========================================
// ✅ RELAÇÃO USUÁRIO <-> SUPLEMENTO (N:N)
// ========================================

model UsuarioSuplemento {
  id           Int      @id @default(autoincrement())
  usuarioId    Int
  suplementoId Int
  ativadoEm    DateTime @default(now())

  usuario    Usuario    @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  suplemento Suplemento @relation(fields: [suplementoId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, suplementoId])
  @@index([usuarioId])
  @@index([suplementoId])
  @@map("usuario_suplemento")
}

// ========================================
// ✅ HOMEBREWS
// ========================================

model Homebrew {
  id        Int     @id @default(autoincrement())
  codigo    String // Gerado automaticamente: "USER_{userId}_HB_{timestamp}"
  nome      String
  descricao String? @db.Text

  // ✅ Tipo de conteúdo homebrew
  tipo TipoHomebrewConteudo

  // ✅ Status
  status StatusPublicacao @default(RASCUNHO)

  // ✅ Dono
  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  // ✅ Dados estruturados (JSON) - Estrutura varia por tipo
  // Para TRILHA: { classeId, nivelRequisito, habilidades: [...] }
  // Para ORIGEM: { pericias: [...], habilidades: [...] }
  // Para EQUIPAMENTO: { tipo, categoria, espacos, danos: [...] }
  // Para PODER_GENERICO: { requisitos, efeitos, mecanicas }
  // Para TECNICA_AMALDICOADA: { habilidades: [...], requisitos }
  dados Json

  // ✅ Metadados
  tags   Json? // ["Customizado", "Homebrew", "Experimental"]
  versao String @default("1.0.0")

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@unique([usuarioId, codigo])
  @@index([usuarioId])
  @@index([tipo])
  @@index([status])
  @@index([usuarioId, criadoEm])
  @@index([status, criadoEm])
  @@map("homebrews")
}
