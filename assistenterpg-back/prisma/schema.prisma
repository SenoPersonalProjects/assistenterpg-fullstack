  @@index([personagemCampanhaId])
  @@index([equipamentoId])
  @@map("inventario_item_campanha")
}

model InventarioItemCampanhaModificacao {
  id            Int @id @default(autoincrement())
  itemId        Int
  modificacaoId Int

  item        InventarioItemCampanha @relation(fields: [itemId], references: [id], onDelete: Cascade)
  modificacao ModificacaoEquipamento @relation(fields: [modificacaoId], references: [id])

  @@unique([itemId, modificacaoId])
  @@map("inventario_item_campanha_modificacao")
